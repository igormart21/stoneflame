# Shopify Storefront API
# The Storefront token is public by design (read-only products + cart),
# so exposing it to the browser via NEXT_PUBLIC_* is safe and expected.
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=fcc3f6-xe.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=
NEXT_PUBLIC_SHOPIFY_API_VERSION=2025-10

# Market context: store operates in Brazil / Portuguese
NEXT_PUBLIC_SHOPIFY_COUNTRY=BR
NEXT_PUBLIC_SHOPIFY_LANGUAGE=PT

# Secret shared with the Shopify webhook that revalidates the site on product changes
SHOPIFY_REVALIDATION_SECRET=
